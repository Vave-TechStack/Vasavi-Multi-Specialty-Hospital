{
  "name": "vasavi-hospital-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev src/server.ts",
    "build": "npx prisma generate --schema ../prisma/schema.prisma && tsc",
    "start": "node dist/server.js",
    "lint": "eslint . --ext .ts",
    "prisma:generate": "prisma generate --schema ../prisma/schema.prisma",
    "prisma:migrate": "prisma migrate deploy --schema ../prisma/schema.prisma",
    "prisma:seed": "ts-node src/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "5.12.0",
    "@types/bcryptjs": "2.4.6",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.17",
    "@types/jsonwebtoken": "9.0.7",
    "@types/node": "20.11.30",
    "bcryptjs": "2.4.3",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "4.22.2",
    "express-rate-limit": "7.2.0",
    "helmet": "7.0.0",
    "jsonwebtoken": "9.0.2",
    "pdfkit": "^0.19.1",
    "prisma": "5.12.0",
    "socket.io": "4.8.3",
    "ts-node": "10.9.2",
    "typescript": "5.4.5",
    "zod": "3.22.4"
  },
  "devDependencies": {
    "@types/pdfkit": "^0.17.6",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-prettier": "5.0.1",
    "prettier": "3.2.5",
    "ts-node-dev": "2.0.0"
  }
}
